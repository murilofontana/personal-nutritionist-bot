{
  "name": "personal-nutritionist-bot",
  "version": "1.0.0",
  "main": "dist/bot.js",
  "scripts": {
    "start": "tsx src/bot.ts",
    "build": "tsc",
    "test": "jest --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "testMatch": [
      "**/tests/**/*.test.ts"
    ]
  },
  "author": ">[SEU NOME] Fontana",
  "license": "ISC",
  "description": "Personal Telegram bot for tracking daily calorie and macro intake using a pluggable LLM",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@grammyjs/conversations": "^2.1.1",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "grammy": "^1.41.1",
    "openai": "^6.27.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
